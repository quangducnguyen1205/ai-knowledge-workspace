# Workspace Core HTTP
SERVER_PORT=8081
WORKSPACE_CORE_MAX_FILE_SIZE=200MB
WORKSPACE_CORE_MAX_REQUEST_SIZE=200MB

# External FastAPI dependency (Repo A)
FASTAPI_BASE_URL=http://localhost:8000
FASTAPI_CONNECT_TIMEOUT=5s
FASTAPI_READ_TIMEOUT=30s

# Repo B local PostgreSQL
WORKSPACE_CORE_POSTGRES_PORT=5434
WORKSPACE_CORE_POSTGRES_DB=workspace_core
WORKSPACE_CORE_POSTGRES_USER=workspace_core
WORKSPACE_CORE_POSTGRES_PASSWORD=workspace_core

# Repo B local Elasticsearch
ELASTICSEARCH_PORT=9201
ELASTICSEARCH_IMAGE=docker.elastic.co/elasticsearch/elasticsearch:8.11.1
ELASTICSEARCH_JAVA_OPTS='-Xms512m -Xmx512m'

# Repo B local MinIO object storage
WORKSPACE_CORE_OBJECT_STORAGE_ENDPOINT=http://localhost:9000
WORKSPACE_CORE_OBJECT_STORAGE_REGION=us-east-1
WORKSPACE_CORE_OBJECT_STORAGE_BUCKET=workspace-media
WORKSPACE_CORE_OBJECT_STORAGE_ACCESS_KEY=minioadmin
WORKSPACE_CORE_OBJECT_STORAGE_SECRET_KEY=minioadmin
WORKSPACE_CORE_OBJECT_STORAGE_PATH_STYLE_ACCESS=true
WORKSPACE_CORE_OBJECT_STORAGE_PORT=9000
WORKSPACE_CORE_OBJECT_STORAGE_CONSOLE_PORT=9001
# MINIO_IMAGE=minio/minio:latest
# MINIO_MC_IMAGE=minio/mc:latest

# Repo B local Kafka event transport
KAFKA_IMAGE=apache/kafka:4.0.2
WORKSPACE_CORE_KAFKA_PORT=9092
WORKSPACE_CORE_KAFKA_BOOTSTRAP_SERVERS=localhost:9092
WORKSPACE_CORE_KAFKA_PROCESSING_REQUESTED_TOPIC=asset.processing.requested.v1
WORKSPACE_CORE_KAFKA_PROCESSING_RESULT_TOPIC=asset.processing.result.v1
WORKSPACE_CORE_KAFKA_INDEXING_REQUESTED_TOPIC=asset.indexing.requested.v1
WORKSPACE_CORE_KAFKA_PROCESSING_RESULT_LISTENER_ENABLED=false
WORKSPACE_CORE_KAFKA_PROCESSING_RESULT_CONSUMER_GROUP=workspace-processing-result-v1
WORKSPACE_CORE_KAFKA_PROCESSING_RESULT_AUTO_OFFSET_RESET=latest
WORKSPACE_CORE_KAFKA_INDEXING_LISTENER_ENABLED=false
WORKSPACE_CORE_KAFKA_INDEXING_CONSUMER_GROUP=workspace-search-indexer-v1
WORKSPACE_CORE_KAFKA_INDEXING_AUTO_OFFSET_RESET=latest
WORKSPACE_CORE_KAFKA_SEND_TIMEOUT=10s
WORKSPACE_CORE_KAFKA_ENABLED=false
WORKSPACE_CORE_KAFKA_LOGGING_PLACEHOLDER_ENABLED=false

# Derived search indexing; explicit indexing remains available, automatic request creation is opt-in
WORKSPACE_CORE_SEARCH_INDEXING_AUTO_REQUEST_ENABLED=false
# Manual search smoke controls: none or relay_indexing_outbox_once
WORKSPACE_CORE_SEARCH_SMOKE_COMMAND=none
# Required only for relay_indexing_outbox_once
WORKSPACE_CORE_SEARCH_SMOKE_INDEXING_OUTBOX_EVENT_ID=

# Processing trigger mode: direct_upload (default) or kafka_request (explicit local/manual transition mode)
WORKSPACE_CORE_PROCESSING_TRIGGER_MODE=direct_upload
# Manual smoke controls: none, relay_request_outbox_once, or handle_result_file_once
WORKSPACE_CORE_PROCESSING_SMOKE_COMMAND=none
# Required only for relay_request_outbox_once
WORKSPACE_CORE_PROCESSING_SMOKE_REQUEST_OUTBOX_EVENT_ID=
# Required only for handle_result_file_once
WORKSPACE_CORE_PROCESSING_SMOKE_RESULT_EVENT_FILE=

# Manual operator recovery controls: none, retry_failed_result_event_once, or requeue_stuck_outbox_event_once
WORKSPACE_CORE_PROCESSING_RECOVERY_COMMAND=none
# Required only for retry_failed_result_event_once
WORKSPACE_CORE_PROCESSING_RECOVERY_RESULT_EVENT_ID=
# Required only for requeue_stuck_outbox_event_once
WORKSPACE_CORE_PROCESSING_RECOVERY_OUTBOX_EVENT_ID=
# Minimum age before a selected PUBLISHING outbox row can be requeued; empty and negative values are rejected
WORKSPACE_CORE_PROCESSING_RECOVERY_MINIMUM_PUBLISHING_AGE=5m

# Outbox relay foundation; disabled until it is manually invoked against Kafka in later local checks
WORKSPACE_CORE_OUTBOX_RELAY_ENABLED=false
WORKSPACE_CORE_OUTBOX_RELAY_BATCH_SIZE=20
WORKSPACE_CORE_OUTBOX_RELAY_MAX_ATTEMPTS=5
WORKSPACE_CORE_OUTBOX_RELAY_RETRY_DELAY=30s

# Optional smoke helper overrides
# WORKSPACE_CORE_BASE_URL=http://localhost:8081
# SMOKE_POLL_INTERVAL_SECONDS=3
# SMOKE_POLL_TIMEOUT_SECONDS=180

# Optional later milestone
# WORKSPACE_CORE_REDIS_PORT=6380
