# Workspace Core HTTP
SERVER_PORT=8081
WORKSPACE_CORE_MAX_FILE_SIZE=200MB
WORKSPACE_CORE_MAX_REQUEST_SIZE=200MB

# External FastAPI dependency (Repo A)
FASTAPI_BASE_URL=http://localhost:8000
FASTAPI_CONNECT_TIMEOUT=5s
FASTAPI_READ_TIMEOUT=30s

# Repo B local PostgreSQL
WORKSPACE_CORE_POSTGRES_PORT=5434
WORKSPACE_CORE_POSTGRES_DB=workspace_core
WORKSPACE_CORE_POSTGRES_USER=workspace_core
WORKSPACE_CORE_POSTGRES_PASSWORD=workspace_core

# Repo B local Elasticsearch
ELASTICSEARCH_PORT=9201
ELASTICSEARCH_IMAGE=docker.elastic.co/elasticsearch/elasticsearch:8.11.1
ELASTICSEARCH_JAVA_OPTS=-Xms512m -Xmx512m

# Optional smoke helper overrides
# WORKSPACE_CORE_BASE_URL=http://localhost:8081
# SMOKE_POLL_INTERVAL_SECONDS=3
# SMOKE_POLL_TIMEOUT_SECONDS=180

# Optional later milestone
# WORKSPACE_CORE_REDIS_PORT=6380
