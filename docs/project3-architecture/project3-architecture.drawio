      <root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="c2" value="AI Knowledge Workspace Project3 Architecture" style="text;html=1;strokeColor=none;fillColor=none;fontSize=34;fontStyle=1;fontColor=#111827;align=left;verticalAlign=top;" vertex="1" parent="1"><mxGeometry x="52" y="38" width="1450" height="48" as="geometry"/></mxCell><mxCell id="c3" value="Spring Boot owns product state and assistant API; Kafka handles media events; FastAPI executes media tasks and LLM prompts." style="text;html=1;strokeColor=none;fillColor=none;fontSize=18;fontStyle=0;fontColor=#4b5563;align=left;verticalAlign=top;" vertex="1" parent="1"><mxGeometry x="54" y="86" width="2100" height="34" as="geometry"/></mxCell><mxCell id="c4" value="Docker Compose Local Stack" style="rounded=0;whiteSpace=wrap;html=1;fillColor=white;strokeColor=#6b7280;fontSize=20;fontStyle=1;align=left;verticalAlign=top;spacing=8;dashed=1;dashPattern=12 8" vertex="1" parent="1"><mxGeometry x="44" y="124" width="2912" height="1430" as="geometry"/></mxCell><mxCell id="c5" value="1. Client / API / Auth Boundary" style="rounded=0;whiteSpace=wrap;html=1;fillColor=white;strokeColor=#111827;fontSize=18;fontStyle=1;align=left;verticalAlign=top;spacing=8" vertex="1" parent="1"><mxGeometry x="95" y="175" width="2760" height="260" as="geometry"/></mxCell><mxCell id="c6" value="7. Observability" style="rounded=0;whiteSpace=wrap;html=1;fillColor=white;strokeColor=#111827;fontSize=18;fontStyle=1;align=left;verticalAlign=top;spacing=8" vertex="1" parent="1"><mxGeometry x="95" y="500" width="290" height="430" as="geometry"/></mxCell><mxCell id="c7" value="2. Spring Boot Product Core" style="rounded=0;whiteSpace=wrap;html=1;fillColor=white;strokeColor=#111827;fontSize=18;fontStyle=1;align=left;verticalAlign=top;spacing=8" vertex="1" parent="1"><mxGeometry x="430" y="500" width="790" height="560" as="geometry"/></mxCell><mxCell id="c8" value="3. Kafka Event Backbone" style="rounded=0;whiteSpace=wrap;html=1;fillColor=white;